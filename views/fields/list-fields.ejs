<%- include('../components/header.ejs') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                    <h2 class="card-title mb-4 fw-bold">Available Fields</h2>
                    <% if (locals.userlog.role === 'admin') { %>
                        <a class="btn btn-success" href="/admin/fields/create">Create new field</a>
                    <% } %>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped" id="tblFields">
                            <thead class="table-dark">
                                <tr>
                                    <th>Field Name</th>
                                    <th>Price / Hour</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% fields.forEach(field => { %>
                                    <tr>
                                        <td>
                                            <%= field.name %>
                                        </td>
                                        <td>Bs. 
                                            <%= field.pricePerHour %>
                                        </td>
                                        <td class="text-center">
                                            <a class="btn btn-success btn-sm px-4" href="/fields/<%= field.id %>">
                                                View Details
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>