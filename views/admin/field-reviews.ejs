<%- include('../components/header.ejs') %>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="h3 mb-0">Gestión de Reseñas</h1>
                        <p class="text-muted">Cancha: <strong class="text-primary">
                                <%= field.name %>
                            </strong></p>
                    </div>
                    <a href="/admin/fields" class="btn btn-secondary">Volver a Canchas</a>
                </div>

                <div class="card border-0 bg-light">
                    <div class="card-body p-4">
                        <% if (!reviews || reviews.length===0) { %>
                            <div class="alert alert-warning text-center mb-0">
                                Esta cancha aún no tiene reseñas de los clientes.
                            </div>
                            <% } else { %>
                                <div class="row g-3">
                                    <% reviews.forEach(review=> { %>
                                        <div class="col-12">
                                            <div class="card border border-light-subtle">
                                                <div class="card-body d-flex justify-content-between align-items-start">

                                                    <div>
                                                        <h6 class="fw-bold mb-1">
                                                            <%= review.user ? review.user.name : 'Usuario Anónimo' %>
                                                        </h6>

                                                        <div class="mb-2">
                                                            <span class="badge bg-primary text-white"
                                                                style="font-size: 0.9rem;">
                                                                Calificación: <%= review.rating %> / 5
                                                            </span>

                                                            <span class="text-muted ms-2" style="font-size: 0.8rem;">
                                                                <%= new Date(review.createdAt).toLocaleDateString() %>
                                                            </span>
                                                        </div>

                                                        <p class="mb-0 text-secondary">
                                                            <%= review.comment ? review.comment : '(Sin comentario)' %>
                                                        </p>
                                                    </div>

                                                    <form action="/admin/reviews/<%= review.id %>/delete" method="POST"
                                                        onsubmit="return confirm('¿Seguro que quieres borrar esta reseña?')">
                                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                                            Borrar
                                                        </button>
                                                    </form>

                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                                <% } %>
                    </div>
                </div>

            </div>
        </div>
    </div>
    </body>

    </html>