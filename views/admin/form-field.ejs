<%- include('../components/header.ejs') %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card">
                    <div class="card-body p-4">
                        <h2 class="card-title mb-4 fw-bold">
                            <%= field ? 'Editar Cancha' : 'Crear Nueva Cancha' %>
                        </h2>
                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="" method="POST">

                                    <div class="mb-3">
                                        <label class="form-label">Nombre de la Cancha</label>
                                        <input type="text" class="form-control" name="name" placeholder="Ej: Cancha 1"
                                            value="<%= field ? field.name : '' %>">
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Precio por Hora (Bs)</label>
                                        <input type="number" step="0.01" class="form-control" name="pricePerHour"
                                            value="<%= field ? field.pricePerHour : '' %>">
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label">Tipo de Cancha</label>
                                        <select class="form-select" name="fieldTypeId">
                                            <% fieldTypes.forEach(type=> { %>
                                                <option value="<%= type.id %>" <%=(field && field.fieldTypeId===type.id)
                                                    ? 'selected' : '' %>>
                                                    <%= type.name %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>

                                    <% if (field) { %>
                                        <div class="mb-4">
                                            <label class="form-label fw-bold">Estado de la Cancha</label>
                                            <select class="form-select" name="status">
                                                <option value="available" <%=field.status==='available' ? 'selected'
                                                    : '' %>>Habilitada (Disponible)</option>
                                                <option value="unavailable" <%=field.status==='unavailable' ? 'selected'
                                                    : '' %>>Deshabilitada (En Mantenimiento)</option>
                                            </select>
                                        </div>
                                        <% } %>

                                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                                <a href="/admin/fields" class="btn btn-secondary">Cancelar</a>
                                                <button type="submit" class="btn btn-primary">
                                                    <%= field ? 'Guardar Cambios' : 'Crear Cancha' %>
                                                </button>
                                            </div>

                                </form>
                    </div>
                </div>
            </div>
        </div>
    </div>