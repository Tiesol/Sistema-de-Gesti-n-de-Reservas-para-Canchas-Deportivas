<%- include('../components/header.ejs') %>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h2 class="card-title fw-bold mb-0">Gestión de Horarios</h2>
                                <p class=" mb-0">Cancha: <strong class="text-primary">
                                        <%= field.name %>
                                    </strong></p>
                            </div>
                            <div>
                                <a href="/admin/fields" class="btn btn-secondary me-2">Volver</a>
                                <button class="btn btn-success" data-bs-toggle="modal"
                                    data-bs-target="#createTimeSlotModal">
                                    Add TimeSlot
                                </button>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Hora Inicio</th>
                                        <th>Hora Fin</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!locals.timeSlots || timeSlots.length===0) { %>
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">
                                                No hay horarios configurados para esta cancha todavía.
                                            </td>
                                        </tr>
                                        <% } else { %>
                                            <% timeSlots.forEach(timeslot=> { %>
                                                <tr>
                                                    <td><span class="fw-bold fs-6">
                                                            <%= timeslot.date %>
                                                        </span></td>
                                                    <td class="fw-bold">
                                                        <%= timeslot.startTime %>
                                                    </td>
                                                    <td class="fw-bold">
                                                        <%= timeslot.endTime %>
                                                    </td>
                                                    <td class="text-center">
                                                        <button class="btn btn-primary btn-sm px-3"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#editTimeSlotModal<%= timeslot.id %>">
                                                            Edit
                                                        </button>

                                                        <form
                                                            action="/admin/fields/<%= field.id %>/timeslots/<%= timeslot.id %>/delete"
                                                            method="POST" class="d-inline"
                                                            onsubmit="return confirm('¿Seguro que deseas borrar este horario?')">
                                                            <button type="submit"
                                                                class="btn btn-danger btn-sm px-3">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>

                                                <div class="modal fade" id="editTimeSlotModal<%= timeslot.id %>" tabindex="-1"
                                                    aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Editar Horario</h5>
                                                                <button type="button" class="btn-close"
                                                                    data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body text-start">
                                                                <form
                                                                    action="/admin/fields/<%= field.id %>/timeslots/<%= timeslot.id %>/edit"
                                                                    method="POST">
                                                                    <div class="mb-3">
                                                                        <label class="form-label">Fecha del
                                                                            Horario</label>
                                                                        <input type="date" class="form-control"
                                                                            name="date" value="<%= timeslot.date %>" required>
                                                                    </div>
                                                                    <div class="row">
                                                                        <div class="col-6 mb-3">
                                                                            <label class="form-label">Hora
                                                                                Inicio</label>
                                                                            <input type="time" class="form-control"
                                                                                name="startTime"
                                                                                value="<%= timeslot.startTime %>" required>
                                                                        </div>
                                                                        <div class="col-6 mb-3">
                                                                            <label class="form-label">Hora Fin</label>
                                                                            <input type="time" class="form-control"
                                                                                name="endTime" value="<%= timeslot.endTime %>"
                                                                                required>
                                                                        </div>
                                                                    </div>
                                                                    <div class="text-end mt-3">
                                                                        <button type="button" class="btn btn-secondary"
                                                                            data-bs-dismiss="modal">Cancelar</button>
                                                                        <button type="submit"
                                                                            class="btn btn-primary">Guardar
                                                                            Cambios</button>
                                                                    </div>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="createTimeSlotModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Nuevo Horario</h5>
                </div>
                <div class="modal-body text-start">
                    <form action="/admin/fields/<%= field.id %>/timeslots/create" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Fecha del Horario</label>
                            <input type="date" class="form-control" name="date" required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Hora Inicio</label>
                                <input type="time" class="form-control" name="startTime" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Hora Fin</label>
                                <input type="time" class="form-control" name="endTime" required>
                            </div>
                        </div>
                        <div class="text-end mt-3">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Crear Horario</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
