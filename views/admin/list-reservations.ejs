<%- include('../components/header.ejs') %>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h2 class="card-title fw-bold mb-0">Ver todas las reservas</h2>
                                <p class="mb-0 text-muted">Admin</p>
                            </div>
                            <div>
                                <a href="/admin/fields" class="btn btn-secondary me-2">Volver</a>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Cancha</th>
                                        <th>Fecha</th>
                                        <th>Horario</th>
                                        <th>Estado</th>
                                        <th class="text-center">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!reservations || reservations.length === 0) { %>
                                        <tr>
                                            <td colspan="6" class="text-center py-4 text-muted">
                                                No hay reservas todavía.
                                            </td>
                                        </tr>
                                    <% } else { %>
                                        <% reservations.forEach(reservation => { %>
                                            <tr>
                                                <td>
                                                    <%= reservation.user ? reservation.user.name : '-' %>
                                                </td>
                                                <td>
                                                    <%= reservation.timeSlot && reservation.timeSlot.field ? reservation.timeSlot.field.name : '-' %>
                                                </td>
                                                <td>
                                                    <%= reservation.timeSlot ? reservation.timeSlot.date : '-' %>
                                                </td>
                                                <td>
                                                    <%= reservation.timeSlot ? (reservation.timeSlot.startTime + ' - ' + reservation.timeSlot.endTime) : '-' %>
                                                </td>
                                                <td>
                                                    <% if (reservation.status === 'confirmed') { %>
                                                        <span class="badge bg-success">Confirmada</span>
                                                    <% } else if (reservation.status === 'cancelled') { %>
                                                        <span class="badge bg-secondary">Cancelada</span>
                                                    <% } else if (reservation.status === 'completed') { %>
                                                        <span class="badge bg-info">Completada</span>
                                                    <% } else { %>
                                                        <span class="badge bg-info"><%= reservation.status %></span>
                                                    <% } %>
                                                </td>
                                                <td class="text-center">
                                                    <form action="/admin/reservations/<%= reservation.id %>/status" method="POST" class="d-flex justify-content-center">
                                                        <select name="status" class="form-select form-select-sm" style="width:auto">
                                                            <option value="confirmed" <%= reservation.status === 'confirmed' ? 'selected' : '' %>>Confirmada</option>
                                                            <option value="cancelled" <%= reservation.status === 'cancelled' ? 'selected' : '' %>>Cancelada</option>
                                                            <option value="completed" <%= reservation.status === 'completed' ? 'selected' : '' %>>Completada</option>
                                                        </select>
                                                        <button type="submit" class="btn btn-primary btn-sm ms-2">Cambiar</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>


