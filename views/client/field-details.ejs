<%- include('../components/header.ejs') %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <h1 class="mb-4">Detalles de la cancha</h1>

                <div class="card mb-4">
                    <div class="card-body">
                        <h2 class="h5 mb-3"><%= field.name %></h2>
                        <p class="mb-1"><strong>Tipo:</strong> <%= field.fieldType ? field.fieldType.name : 'Sin tipo' %></p>
                        <p class="mb-1"><strong>Precio:</strong> Bs. <%= field.pricePerHour %></p>
                        <p class="mb-1"><strong>Estado:</strong> <%= field.status === 'available' ? 'Activa' : 'Inactiva' %></p>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Horarios disponibles</h2>
                        <% if (!timeSlots || timeSlots.length === 0) { %>
                            <div class="alert alert-secondary">No hay horarios disponibles para esta cancha.</div>
                        <% } else { %>
                            <div class="list-group">
                                <% timeSlots.forEach(timeslot => { %>
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong><%= timeslot.date %> · <%= timeslot.startTime %> - <%= timeslot.endTime %></strong>
                                            <div class="text-muted">Disponible</div>
                                        </div>
                                        <a href="/clients/fields/<%= field.id %>/reserve/<%= timeslot.id %>" class="btn btn-primary">Reservar</a>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Reseñas</h2>
                        <p class="text-muted">Aún no hay reseñas disponibles.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>