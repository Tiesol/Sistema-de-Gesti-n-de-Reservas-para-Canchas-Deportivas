<%- include('../components/header.ejs') %>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <h1 class="mb-4">Detalles de la cancha</h1>

                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 mb-3 fw-bold text-primary"><%= field.name %></h2>
                        <p class="mb-1"><strong>Tipo:</strong> <%= field.fieldType ? field.fieldType.name : 'Sin tipo' %></p>
                        <p class="mb-1"><strong>Precio:</strong> Bs. <%= field.pricePerHour %></p>
                        <p class="mb-1"><strong>Estado:</strong> 
                            <% if (field.status === 'available') { %>
                                <span class="badge bg-success">Activa</span>
                            <% } else { %>
                                <span class="badge bg-danger">Inactiva</span>
                            <% } %>
                        </p>
                    </div>
                </div>

                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 mb-3 fw-bold">Horarios disponibles</h2>
                        <% if (!timeSlots || timeSlots.length === 0) { %>
                            <div class="alert alert-secondary mb-0">No hay horarios disponibles para esta cancha en este momento.</div>
                        <% } else { %>
                            <div class="list-group">
                                <% timeSlots.forEach(timeslot => { %>
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong><i class="bi bi-calendar-event me-2"></i><%= timeslot.date %></strong> 
                                            <span class="ms-2 badge bg-light text-dark border"><%= timeslot.startTime %> - <%= timeslot.endTime %></span>
                                            <div class="text-success small mt-1 fw-semibold">Disponible</div>
                                        </div>
                                        <a href="/clients/fields/<%= field.id %>/reserve/<%= timeslot.id %>" class="btn btn-primary btn-sm px-3">Reservar</a>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 mb-4 fw-bold">Reseñas</h2>
                        
                        <% if (!reviews || reviews.length === 0) { %>
                            <p class="text-muted mb-0">Aún no hay reseñas disponibles. ¡Anímate a ser el primero en calificarla después de jugar!</p>
                        <% } else { %>
                            <div class="row g-3">
                                <% reviews.forEach(review => { %>
                                    <div class="col-md-6">
                                        <div class="card bg-light h-100 border-0">
                                            <div class="card-body p-3">
                                                
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <h6 class="card-title mb-0 fw-bold text-dark">
                                                        <%= review.user.name %>
                                                    </h6>
                                                </div>
                                                
                                                <div class="mb-2">
                                                    <span class="badge bg-primary text-white" style="font-size: 0.85rem;">
                                                        Calificación: <%= review.rating %> / 5
                                                    </span>
                                                    <span class="text-muted ms-2" style="font-size: 0.8rem;">
                                                        <%= new Date(review.createdAt).toLocaleDateString('es-ES') %>
                                                    </span>
                                                </div>
                                                
                                                <p class="card-text text-secondary mb-0" style="font-size: 0.9rem;">
                                                    <% if (review.comment) { %>
                                                        "<%= review.comment %>"
                                                    <% } else { %>
                                                        <span class="fst-italic text-muted">Sin comentario adicional.</span>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>